pipeline {
    agent any

    stages {
        stage('Unit Tests - Backend') {
            agent {
                docker {
                    image 'snakee/golang-junit:1.21'
                    reuseNode true
                }
            }
            environment {
                // The container runs as UID 1000 with no writable HOME, so Go's
                // default cache path (/.cache/go-build) can't be created. Point
                // HOME/caches at the writable workspace instead.
                GOCACHE = "${WORKSPACE}/.cache/go-build"
                GOPATH = "${WORKSPACE}/.cache/go-path"
                HOME = "${WORKSPACE}"
            }
            steps {
                dir('bugtracker-backend') {
                    sh '''
                        go test -v ./... 2>&1 | go-junit-report > tests-results.xml
                        
                        # Generate coverage report
                        go test -coverprofile=coverage.out covermode=atomic ./...
                        go tool cover -html=coverage.out -o coverage.html

                        mkdir -p reports
                        mv coverage.html reports/
                    '''
                }
            }
            post {
                always {
                    junit 'bugtracker-backend/tests-results.xml'
                    publishHTML target {
                        reportDir 'bugtracker-backend/reports'
                        reportFiles 'coverage.html'
                        reportName 'Backend Coverage Report'
                    }
                }
            }
        }
        stage('Unit Test - Frontend') {
            agent {
                docker {
                    image 'node:20-alpine'
                    reuseNode true
                }
            }
            steps {
                dir('bugtracker-frontend') {
                    echo 'Running unit tests for frontend...'
                    sh '''
                        npm ci
                        npm test
                    '''
                }
            }
            post {
                always {
                    junit 'bugtracker-frontend/test-results.xml'
                }
            }
        }
    }
}
